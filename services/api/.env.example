# LLM 配置（使用 DeepSeek API，兼容 OpenAI SDK）
OPENAI_API_KEY=your-deepseek-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
CODER_MODEL=deepseek-coder
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY_S=1.0

# CORS 配置（逗号分隔，支持生产环境部署）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 图像生成配置（火山引擎 Ark / Seedream 5.0）
ARK_API_KEY=your-ark-api-key-here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDREAM_MODEL=doubao-seedream-5-0-260128

# TTS 配置（使用 edge-tts，免费无需 API key）
TTS_VOICE=zh-CN-XiaoxiaoNeural

# 服务配置
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
