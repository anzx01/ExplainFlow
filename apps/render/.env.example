# Render server config
RENDER_PORT=3001
PYTHON_API_URL=http://localhost:8000

# Leave browser variables empty for automatic discovery.
# Supported overrides:
# REMOTION_BROWSER_EXECUTABLE=/absolute/path/to/chrome-or-chromium
# REMOTION_CHROME_HEADLESS_SHELL=/absolute/path/to/chrome-headless-shell
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/absolute/path/to/playwright/chromium
# CHROME_PATH=/absolute/path/to/chrome
# GOOGLE_CHROME_BIN=/absolute/path/to/chrome

# Optional output/cache paths. Relative paths are resolved from the repo root.
# EXPLAINFLOW_OUTPUT_DIR=outputs
# EXPLAINFLOW_MUSIC_DIR=outputs/music
# EXPLAINFLOW_RENDER_GENERATED_DIR=apps/render/generated

# Optional font overrides. Use OS path delimiter for lists: ";" on Windows, ":" on macOS/Linux.
# EXPLAINFLOW_GLYPH_FONT=/absolute/path/to/cjk-font.ttc
# EXPLAINFLOW_GLYPH_FONTS=/path/one.ttc:/path/two.otf
# EXPLAINFLOW_LATIN_GLYPH_FONT=/absolute/path/to/latin-font.ttf

# Optional ffmpeg overrides. Usually not needed when ffmpeg is on PATH.
# FFMPEG_PATH=/absolute/path/to/ffmpeg
# FFPROBE_PATH=/absolute/path/to/ffprobe
